{
  "version": 2,
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/",
      "destination": "/candidate/authentication/login",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/home",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/$1.html"
    }
  ]
}